  edintinf:belongsTo <http://vocab.linkeddata.es/datosabiertos/recurso/sector-publico/territorio/barrio/ARGUELLES>;
  edintinf:containsFacility <http://vocab.linkeddata.es/datosabiertos/recurso/equipamiento-municipal/87027.0>;
