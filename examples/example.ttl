<http://vocab.linkeddata.es/datosabiertos/recurso/equipamiento-municipal/84763> a
    edintinf:Facility;
  dct:identifier "84763";
  <http://schema.org/address> <http://vocab.linkeddata.es/datosabiertos/recurso/direccion-postal/28005>;
  <http://schema.org/openingHours> "De apertura   De lunes a viernes, de 8:30 a 21:30 horas Sábados, de 10 a 15 horas y de 16 a 21:30 horas Domingos cerrado.   De atención de los trabajadores sociales comunitarios (no es necesaria cita previa)   Lunes a jueves, de 9 a 19 horas Viernes, de 9 a 14 horas Julio y agosto, de 9 a 15 horas";
  edintinf:belongsTo <http://vocab.linkeddata.es/datosabiertos/recurso/sector-publico/territorio/barrio/EMBAJADORES>;
  edintinf:hasInfrastructureType <edintkos:CentrosServiciosSociales>;
