<http://vocab.linkeddata.es/datosabiertos/recurso/equipamiento-municipal/10269952>
  a edintinf:Facility;
  dct:identifier "10269952";
  <http://schema.org/address> <http://vocab.linkeddata.es/datosabiertos/recurso/direccion-postal/28016>;
  <http://schema.org/openingHours> "De lunes a sábados de 8:00 a 21:00 horas.";
  edintinf:belongsTo <http://vocab.linkeddata.es/datosabiertos/recurso/sector-publico/territorio/barrio/NUEVA%20ESPA%C3%91A>;
  edintinf:hasInfrastructureType <edintkos:CentrosServiciosSociales>;
  edintinf:hasObservationPoint <http://vocab.linkeddata.es/datosabiertos/recurso/punto-de-observacion/1341>;
