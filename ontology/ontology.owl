        <Literal xml:lang="es">Ontología de Infraestructura</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:title"/>
        <Literal xml:lang="en">The Infrastructure Ontology</Literal>
    </Annotation>
