        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#intensidad</IRI>
        <Literal xml:lang="es">Intensidad o aforo, número de vehículos en unidad de tiempo (hora, día, mes año). Los habituales son hora y día.</Literal>
    </AnnotationAssertion>
