        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#urbano</IRI>
        <Literal xml:lang="es">Urbano</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#validada</IRI>
        <Literal xml:lang="es">Esta propiedad permite conocer si se ha producido una validación de la observación o no</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#validada</IRI>
        <Literal xml:lang="en">This property states whether the observation is validated or not.</Literal>
    </AnnotationAssertion>
