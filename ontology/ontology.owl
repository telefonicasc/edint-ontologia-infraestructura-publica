        <Literal xml:lang="es">Tramo definido por un punto de inicio y fin que puede pertenecer a una o más vías</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo</IRI>
