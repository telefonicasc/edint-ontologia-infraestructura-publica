        <AbbreviatedIRI>sosa:hasFeatureOfInterest</AbbreviatedIRI>
        <Literal>has feature of interest</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <AbbreviatedIRI>sosa:hasFeatureOfInterest</AbbreviatedIRI>
        <Literal xml:lang="es">tiene entidad de interés</Literal>
    </AnnotationAssertion>
