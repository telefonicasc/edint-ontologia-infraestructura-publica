    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#composicion</IRI>
        <Literal xml:lang="en">composition</Literal>
    </AnnotationAssertion>
