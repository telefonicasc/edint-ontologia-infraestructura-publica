        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#urbano</IRI>
        <Literal xml:lang="es">Esta propiedad permite describir si el dispositivo es urbano o no.</Literal>
    </AnnotationAssertion>
